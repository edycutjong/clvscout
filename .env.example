# CLV Scout — environment. Copy to .env and fill in for a real deployment.
# Never commit real credentials.

# ── Payment rail ─────────────────────────────────────────────
# Get from: this codebase — "okx" selects the OKX x402 middleware in
# api/rails/okx.ts (the only rail implemented; kept as a var for parity
# with EdgeLedger's config shape).
PAY_RAIL=okx
PORT=4021

# Get from: pick per environment — eip155:1952 = X Layer rehearsal
# (testnet) · eip155:196 = X Layer mainnet (listing network).
X402_NETWORK=eip155:196

# ── Receive address ──────────────────────────────────────────
# Get from: your own X Layer wallet address (any EOA that can receive
# USD₮0). Falls back to a documented burn-style placeholder if unset —
# see config.ts PAYTO_ADDRESS. PAYTO_ADDRESS is the shared/legacy name;
# CLV_PAYTO overrides it for this service specifically.
CLV_PAYTO=0xYourXLayerAddress
PAYTO_ADDRESS=0xYourXLayerAddress

# ── OKX Developer Portal (Facilitator credentials) ──────────
# Get from: https://web3.okx.com/onchainos/dev-portal → create an app →
# API Key / Secret Key / Passphrase. Absent = faithful-local mode: real
# EIP-3009 signature verification still runs, but settlement is recorded
# as an honestly-labeled local-pending receipt instead of a live
# Facilitator call. See api/rails/okx.ts header comment for the full
# real-SDK-vs-faithful-local decision.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

API_BASE_URL=http://localhost:4021
